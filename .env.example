# Fleur d'AmOurs — Variables d'environnement
# Copier en .env et remplir.
# Source unique pour dev local. Prod (Coolify) : variables dans l'UI Coolify.

# --- Next.js / Fleur dev local (npm run dev.vps) ---
# Tunnel SSH vers MariaDB Coolify
SSH_VPS_HOST=
SSH_VPS_USER=root
TUNNEL_LOCAL_PORT=3307
LOCAL_DB=default
LOCAL_USER=mariadb
LOCAL_PASS=
LOCAL_DB_CONTAINER=

USE_NODE_API=true
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=

# MariaDB (rempli par dev-vps depuis LOCAL_*)
# MARIADB_HOST=127.0.0.1
# MARIADB_PORT=3307
DB_PREFIX=wp_

# JWT Auth
JWT_SECRET=
JWT_EXPIRE_HOURS=720

# OpenRouter (IA)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_CREDITS_100=

# FCM (push Android + Web PWA, optionnel)
# Côté serveur (envoi des pushes via FCM HTTP v1)
# FCM_PROJECT_ID=
# Recommandé sur Coolify : monter le JSON comme fichier secret puis :
# FCM_SERVICE_ACCOUNT_FILE=/run/secrets/fcm-service-account.json
# Sinon JSON sur une ligne, ou base64 sans espaces ni retours à la ligne :
# FCM_SERVICE_ACCOUNT_B64=...
# FCM_SERVICE_ACCOUNT_JSON=./config/fcm-service-account.json
#
# Côté navigateur (PWA web push — Firebase Console > Paramètres > Config web)
# NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ton-projet.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=ton-projet-id
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
# NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
# Clé publique VAPID : Firebase Console > Cloud Messaging > Web Push Certificates
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=BN...

# Coolify (optionnel, dashboard admin)
# COOLIFY_API_URL=
# COOLIFY_API_TOKEN=

# --- Hostinger / www.eludein.art (jardin frozen, déploiement SFTP) ---
# Ces variables ne concernent PAS app-fleurdamours.eludein.art (VPS legacy) ni le dev local.
# SFTP_HOST=
# SFTP_USER=
# SFTP_PASSWORD=
