# Fleur d'AmOurs — Variables d'environnement
# Copier en .env et remplir.
# Source unique pour dev local. Prod (Coolify) : variables dans l'UI Coolify.

# --- Next.js / Fleur dev local (npm run dev.vps) ---
# Tunnel SSH vers MariaDB Coolify
SSH_VPS_HOST=
SSH_VPS_USER=root
TUNNEL_LOCAL_PORT=3307
LOCAL_DB=default
LOCAL_USER=mariadb
LOCAL_PASS=
LOCAL_DB_CONTAINER=

USE_NODE_API=true
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=

# MariaDB (rempli par dev-vps depuis LOCAL_*)
# MARIADB_HOST=127.0.0.1
# MARIADB_PORT=3307
DB_PREFIX=wp_

# JWT Auth
JWT_SECRET=
JWT_EXPIRE_HOURS=720

# OpenRouter (IA)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_CREDITS_100=

# FCM (push Android, optionnel)
# FCM_PROJECT_ID=
# FCM_SERVICE_ACCOUNT_JSON=

# Coolify (optionnel, dashboard admin)
# COOLIFY_API_URL=
# COOLIFY_API_TOKEN=

# --- Hostinger / www.eludein.art (jardin frozen, déploiement SFTP) ---
# Ces variables ne concernent PAS app-fleurdamours.eludein.art (VPS legacy) ni le dev local.
# SFTP_HOST=
# SFTP_USER=
# SFTP_PASSWORD=
