# Config Docker Compose — Fleur d'AmOurs (VPS = source unique)
# Copier en docker-compose.env et remplir.
# NE PAS COMMITTER docker-compose.env
#
# Usage:
#   1. Si MariaDB vide : npm run sync:db (config sync-config.env)
#   2. docker compose --env-file docker-compose.env up -d

# --- Base de données (MariaDB) ---
# Local (docker-compose.next.local.yml) : MARIADB_HOST=mariadb (service du compose)
# Coolify : MARIADB_HOST = hostname de la ressource MariaDB (voir sync-config.env LOCAL_HOST)
MARIADB_HOST=mariadb
DB_NAME=default
DB_USER=mariadb
DB_PASSWORD=

# Préfixe des tables WordPress
DB_PREFIX=wp_

# --- JWT ---
JWT_SECRET=

# --- URLs ---
APP_PUBLIC_URL=https://legacy.eludein.art/jardin

# --- OpenRouter (IA) ---
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=  # optionnel, défaut: arcee-ai/trinity-large-preview:free

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=   # Price ID abonnement mensuel (price_...)
STRIPE_PRICE_YEARLY=    # Price ID abonnement annuel (price_...)
STRIPE_PRICE_CREDITS_100=  # Price ID pack 100 crédits (price_...)

# --- Optionnel ---
JWT_EXPIRE_HOURS=720
