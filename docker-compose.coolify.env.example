# Variables pour Coolify — Docker Compose (docker-compose.next.yml)
# À copier dans Coolify → Resource → Environment Variables
# Les valeurs MariaDB correspondent à sync-config.env (LOCAL_*)
#
# Sur Coolify : MariaDB est une ressource SÉPARÉE.
# 1. Activer "Connect to Predefined Network" dans Advanced de la ressource Next.js
# 2. Récupérer le hostname : MariaDB → MariaDB URL (internal) → partie entre @ et :3306
#    Ex. mariadb://mariadb:xxx@a40k0sgowg0ckw4w448k4gko:3306/default → MARIADB_HOST=a40k0sgowg0ckw4w448k4gko

# --- MariaDB (hostname = ID conteneur depuis URL interne) ---
MARIADB_HOST=<id_conteneur_depuis_url_interne>
MARIADB_PORT=3306
MARIADB_DATABASE=default
MARIADB_USER=mariadb
MARIADB_PASSWORD=<valeur de sync-config.env LOCAL_PASS>
DB_PREFIX=wp_

# --- JWT ---
JWT_SECRET=<secret fort>
JWT_EXPIRE_HOURS=720

# --- OpenRouter (IA) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
