{
  "outputs_contract": {
    "goal": "Standardiser les sorties du moteur pour app/RAG.",
    "required_outputs": [
      { "id": "phrase_synthesis", "layer": "L2_interpreted", "template": "[Dynamique] à [stade], sous [climat], dans [trajectoire]" },
